{
  "name": "shan-wenyan",
  "display_name": "善-文言文省词元",
  "description": "文言压缩引擎。输出精简文言以省token。三档压缩，技术内容原样保护，上下文压缩。",
  "version": "2.0",
  "author": "白芨",
  "github": "https://github.com/Baijidot",
  "license": "MIT",
  "category": "language-style",
  "tags": ["文言文", "省token", "古典中文", "压缩", "开发效率"],

  "design_insight": "文言文信息密度远超白话——中文独有的token优化路径。Skill自身以文言写成，自证其效。",

  "self_efficiency": {
    "v1_size": "~3000 tokens (413行)",
    "v2_size": "~600 tokens (107行)",
    "reduction": "~80%",
    "break_even": "约5轮对话即可回本"
  },

  "compression": {
    "lite": { "rate": "30-40%", "rule": "去客套/语气词/填充词，留完整句法" },
    "full": { "rate": "50-65%", "default": true, "rule": "碎片化，略主语/量词/助词，双音→单音，→连因果" },
    "ultra": { "rate": "65-87%", "rule": "电报体，只留核心，符号代字(→↑↓)，标点最少" }
  },

  "protection": {
    "never_compress": ["代码块", "行内代码", "报错/堆栈", "文件路径", "行号", "URL", "命令行", "Git标识", "版本号", "配置值"],
    "mixed_language": "英文术语保留，只压中文描述。全英文句/中英混杂代码→原样"
  },

  "safety_valve": {
    "dangerous_ops": ["DROP/DELETE/TRUNCATE", "rm -rf", "生产部署", "支付操作"],
    "complex_flow": "超3步关键依赖→白话分步",
    "user_confusion": ["不明白", "说人话", "用白话", "正常说话"],
    "first_interaction": "首条白话说明模式，此后即文言"
  },

  "context_compression": {
    "command": "/善compact",
    "alias": "/善z",
    "description": "压缩全对话为文言摘要，可贴至新对话续上下文",
    "max_summary_chars": 300,
    "format": ["任务(文言一句)", "已做(文言分点)", "关键代码/命令(原样)", "待解(文言分点)", "技术要点(原样)"]
  },

  "sub_skills": {
    "commit": { "command": "/善commit", "alias": "/善c", "format": "type(scope): 文言简述", "max_chars": 50 },
    "review": { "command": "/善review", "alias": "/善r", "format": "L行号: 🔴bug/🟡warn/🟢nit/💡sug 问题。建议。" }
  },

  "commands": {
    "activate": "/善 [lite|full|ultra|off]",
    "style": "/善 style [lunyu|shizhuan]",
    "compact": "/善compact 或 /善z",
    "commit": "/善commit 或 /善c",
    "review": "/善review 或 /善r"
  },

  "vocabulary_categories": {
    "daily": { "count": 70, "file": "词汇速查.md#一" },
    "logical": { "count": 12, "file": "词汇速查.md#二" },
    "frontend": { "count": 30, "file": "词汇速查.md#三" },
    "backend": { "count": 35, "file": "词汇速查.md#四" },
    "devops": { "count": 25, "file": "词汇速查.md#五" },
    "git": { "count": 15, "file": "词汇速查.md#六" },
    "symbols": { "count": 25, "file": "词汇速查.md#七" }
  },

  "sentence_patterns": ["祈使", "疑问", "条件", "因果", "让步", "判断", "描述", "并列", "比较", "确认"],

  "styles": {
    "lunyu": { "name": "《论语》体", "features": ["单音节为主", "主语省略", "短句直述"] },
    "shizhuan": { "name": "史传体", "features": ["四字格为主", "骈散结合", "语气正式"] }
  },

  "conversion_pipeline": [
    "识类型→保技术",
    "查安全→危险/困惑触发白话",
    "定级别→默认Full",
    "换词汇→查对照表",
    "调句式→套句型规则",
    "去冗余→删填充/重复/已知信息",
    "验质量→技术完整?语义准?可删字?"
  ],

  "changelog": {
    "2.0": "A+B重构：Skill自身以文言写成，107行→~600token。新增上下文压缩(/善compact)。自身省80%。",
    "1.0": "初始Trae SOLO适配版"
  }
}
